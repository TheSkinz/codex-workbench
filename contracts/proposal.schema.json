{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-workbench/contracts/proposal.schema.json",
  "title": "Workbench Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "objective", "authority", "evidence", "allowed_scope", "blocked_scope", "decision"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "authority": {"enum": ["primary", "supporting", "context-only", "unverified"]},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "allowed_scope": {"type": "array", "items": {"type": "string"}},
    "blocked_scope": {"type": "array", "items": {"type": "string"}},
    "decision": {"enum": ["pending", "approved", "rejected", "blocked"]},
    "next_action": {"type": "string"}
  }
}
