{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-workbench/contracts/loop-run.schema.json",
  "title": "Workbench Loop Run Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "loop", "result", "selected_input", "touched_paths", "evidence", "next_action"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "loop": {"enum": ["capture", "review", "research", "drift", "consolidation", "health"]},
    "result": {"enum": ["proposal", "committed", "no-op", "blocked", "failed"]},
    "selected_input": {"type": ["string", "null"]},
    "touched_paths": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "next_action": {"type": "string", "minLength": 1},
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
