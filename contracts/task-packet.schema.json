{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-workbench/contracts/task-packet.schema.json",
  "title": "Harness Task Packet",
  "description": "Portable contract for handing a bounded task between ChatGPT, Codex, research, and connected tools.",
  "type": "object",
  "additionalProperties": false,
  "required": ["objective", "execution_surface", "authority_lane", "acceptance_checks", "deliverables"],
  "properties": {
    "objective": {"type": "string", "minLength": 1},
    "non_goals": {"type": "array", "items": {"type": "string"}},
    "authoritative_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "authority"],
        "properties": {
          "source": {"type": "string", "minLength": 1},
          "authority": {"enum": ["primary", "supporting", "context-only", "unverified"]},
          "notes": {"type": "string"}
        }
      }
    },
    "execution_surface": {
      "enum": ["chatgpt", "deep-research", "codex", "github", "connected-app", "agent-mode"]
    },
    "authority_lane": {
      "enum": ["read-only", "reversible-implementation", "propose-with-default", "human-gated"]
    },
    "allowed_actions": {"type": "array", "items": {"type": "string"}},
    "blocked_actions": {"type": "array", "items": {"type": "string"}},
    "acceptance_checks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "deliverables": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "verification_evidence": {"type": "array", "items": {"type": "string"}},
    "remaining_risks": {"type": "array", "items": {"type": "string"}},
    "next_action": {"type": "string", "minLength": 1},
    "loop": {"enum": ["capture", "review", "research", "drift", "consolidation", "health"]},
    "input_scope": {"type": "array", "items": {"type": "string"}},
    "write_scope": {"type": "array", "items": {"type": "string"}},
    "expected_artifact": {"type": "string", "minLength": 1},
    "run_mode": {"enum": ["preview", "interactive", "scheduled"]},
    "stop_conditions": {"type": "array", "items": {"type": "string"}},
    "handoff_status": {"enum": ["ready", "needs-decision", "blocked", "complete"]}
  }
}
