{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/codex-workbench/contracts/evidence-record.schema.json",
  "title": "Public Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "sources", "findings", "confidence", "uncertainty", "recommended_action"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "sources": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^https://[A-Za-z0-9](?:[A-Za-z0-9.-]*[A-Za-z0-9])?(?::[0-9]+)?(?:[/?#][^\\s]*)?$"}},
    "findings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "confidence": {"enum": ["high", "medium", "low", "unknown"]},
    "uncertainty": {"type": "array", "items": {"type": "string"}},
    "recommended_action": {"type": "string", "minLength": 1},
    "retrieved": {"type": "string", "minLength": 1}
  }
}
